{
  "name": "business-card-management",
  "main": "src/index.ts",
  "compatibility_date": "2025-12-01",
  "upload_source_maps": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "business-card-db",
      "database_id": "<actual-d1-database-id>"
    }
  ],
  "r2_buckets": [
    {
      "binding": "CARD_IMAGES",
      "bucket_name": "business-card-images"
    }
  ],
  "observability": {
    "enabled": true
  },
  "vars": {
    "APP_TITLE": "名刺共有台帳",
    "ALLOWED_EMAIL_DOMAINS": "nextbrain.pro,nextbrain.biz",
    "ALLOW_DEV_USER_HEADER": "true",
    "MAX_SEARCH_RESULTS": "100",
    "IMAGE_MAX_BYTES": "8388608",
    "OCR_API_URL": "",
    "OCR_API_TOKEN": ""
  }
}
